# 复制此文件为 .env 并填入你的 API Key
OPENAI_API_KEY=sk-your-api-key-here

# 若使用国内智谱等兼容 OpenAI 的接口，填写下面两项（详见 国内免费AI使用说明.md）
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_MODEL=glm-4-flash

# 企查查开放平台（可选，用于 VR 融资数据；详见 data_sources/qcc_client.py）
# 在 https://openapi.qcc.com 申请后填入
# QCC_API_KEY=你的AppKey
# QCC_SECRET_KEY=你的SecretKey

# 飞书开放平台（可选，导出 Excel 后自动上传到飞书云文档；详见 data_sources/feishu_upload.py）
# 在 https://open.feishu.cn 创建自建应用，开通「云文档」权限，获取应用凭证；在云文档中打开目标文件夹，从 URL 获取 folder token
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_FOLDER_TOKEN=目标文件夹的 token（如 fldcnxxx）
